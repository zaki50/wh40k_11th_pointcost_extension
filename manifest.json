{
  "manifest_version": 3,
  "name": "WH40k 11版 ポイントコスト表示",
  "version": "0.2.0",
  "description": "wikiwiki.jp の Warhammer 40k 11版ユニットデータページに、Munitorum Field Manual のポイントコストを挿入して表示します。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://mfm.warhammer-community.com/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "wh40k-pointcost@zakky.org",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
          "required": ["none"]
      }
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://wikiwiki.jp/40k-11th/*"],
      "js": [
        "src/army-map.js",
        "src/normalize.js",
        "src/mfm-parser.js",
        "src/content.js"
      ],
      "css": ["styles/inject.css"],
      "run_at": "document_idle"
    }
  ]
}
